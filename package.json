{
  "name": "psychobalance",
  "version": "0.1.1",
  "description": "Adaptive video sessions driven by real-time heart rate from Polar BLE sensors.",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:next": "next dev renderer -p 3000",
    "dev:electron": "tsc -p tsconfig.electron.json -w",
    "dev:start": "wait-on tcp:3000 file:dist-electron/electron/main.js file:dist-electron/electron/preload.js && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n NEXT,TSC,ELEC -c blue,yellow,green \"npm:dev:next\" \"npm:dev:electron\" \"npm:dev:start\"",
    "build:next": "next build renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:next && npm run build:electron",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p renderer/tsconfig.json --noEmit",
    "package": "npm run build && electron-builder --win nsis",
    "release": "npm run build && electron-builder --win nsis --publish always",
    "start": "electron ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-bluetooth": "^0.0.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  }
}
